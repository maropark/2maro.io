---
const links = [
  { label: 'GitHub',   href: 'https://github.com/maropark',                        color: 'blue'   },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/maropark',                   color: 'teal'   },
  { label: 'Bluesky',  href: 'https://bsky.app/profile/maropark.bsky.social',      color: 'yellow' },
  { label: 'YouTube',  href: 'https://youtube.com/@maropark',                      color: 'red'    },
];
---

<aside class="lost-and-found" aria-label="Social links">
  <span class="pocket-label handwritten">Lost &amp; Found</span>
  <div class="tape-links">
    {links.map(({ label, href, color }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class={`tape-link tape-link--${color}`}
      >
        {label}
      </a>
    ))}
  </div>
</aside>

<style>
  .lost-and-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-sm);
  }

  .pocket-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-pencil);
    opacity: 0.7;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
  }

  .tape-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: center;
  }

  .tape-link {
    display: block;
    font-family: 'Caveat', cursive;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-ink);
    padding: 3px 10px;
    opacity: 0.75;
    transform: rotate(-1.5deg);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
    white-space: nowrap;
  }

  .tape-link:nth-child(even) {
    transform: rotate(1deg);
  }

  .tape-link:hover {
    opacity: 1;
    transform: rotate(0deg) scale(1.05);
  }

  .tape-link--blue   { background: var(--color-ballpoint-blue); color: white; }
  .tape-link--teal   { background: var(--color-washi-teal);      color: white; }
  .tape-link--yellow { background: var(--color-sticky-yellow);   color: var(--color-ink); }
  .tape-link--red    { background: var(--color-stamp-red);        color: white; }
</style>
