---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['torn-edge-wrapper', className]} aria-hidden="true">
  <svg viewBox="0 0 1200 12" preserveAspectRatio="none" class="torn-svg">
    <path
      d="M0,12 L20,4 L40,8 L60,2 L80,9 L100,3 L120,7 L140,1 L160,8 L180,4 L200,10 L220,2 L240,7 L260,4 L280,9 L300,1 L320,8 L340,3 L360,7 L380,2 L400,9 L420,4 L440,8 L460,1 L480,7 L500,3 L520,9 L540,2 L560,8 L580,4 L600,10 L620,1 L640,7 L660,3 L680,9 L700,2 L720,8 L740,4 L760,10 L780,1 L800,7 L820,3 L840,9 L860,2 L880,8 L900,4 L920,10 L940,1 L960,7 L980,3 L1000,9 L1020,2 L1040,8 L1060,4 L1080,10 L1100,1 L1120,7 L1140,3 L1160,9 L1180,2 L1200,12 Z"
      fill="var(--color-paper)"
    />
  </svg>
</div>

<style>
  .torn-edge-wrapper {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .torn-svg {
    display: block;
    width: 100%;
    height: 12px;
  }
</style>
