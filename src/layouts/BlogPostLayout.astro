---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import DateStamp from '../components/DateStamp.astro';
import TagStamp from '../components/TagStamp.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  category?: string;
}

const { title, description, date, tags = [], category = 'journal' } = Astro.props;
const variants: Array<'red' | 'teal' | 'yellow'> = ['red', 'teal', 'yellow'];
---

<BaseLayout title={title} description={description}>

  <article class="blog-post">
    <header class="post-header">
      <div class="post-meta">
        <DateStamp date={date} />
        {category && <span class="post-category handwritten">{category}</span>}
      </div>
      <h1 class="post-title">{title}</h1>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag, i) => (
            <TagStamp tag={tag} variant={variants[i % variants.length]} />
          ))}
        </div>
      )}
    </header>

    <div class="post-body notebook-lines notebook-margin">
      <slot />
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .blog-post {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-kraft);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .post-category {
    font-size: 1rem;
    color: var(--color-washi-teal);
    font-weight: 600;
  }

  .post-title {
    font-size: 2.2rem;
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* Prose styles for blog content */
  .post-body {
    padding-top: var(--space-lg);
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-md);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-xl);
  }

  .post-body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-stamp-red);
    padding-left: var(--space-lg);
    margin: var(--space-lg) 0;
    color: var(--color-pencil);
    font-style: italic;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px dashed var(--color-kraft);
    margin: var(--space-2xl) 0;
  }

  .post-body :global(img) {
    border: 1px solid var(--color-kraft);
    box-shadow: var(--shadow-paper);
    margin: var(--space-lg) 0;
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.7rem;
    }

    .post-body {
      margin-left: 0;
      padding-left: var(--space-md);
    }
  }
</style>
