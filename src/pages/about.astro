---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Author's Note" description="About Maro Park — open-source builder, developer, thinker.">

  <section class="about-page">
    <header class="page-header">
      <h1 class="page-title">Author's Note</h1>
      <p class="page-subtitle handwritten">the person behind the notebook</p>
    </header>

    <div class="about-content">
      <div class="about-photo-wrapper taped-image">
        <img src="/blog-profile.jpeg" alt="Maro" class="about-photo" />
      </div>

      <div class="about-text notebook-lines">
        <h2>Hey, I'm Maro.</h2>
        <p>
          Ex-immigrant rights organizer, coder, and creator.
        </p>
        <p>
          I build for community, resistance, and expression.
          Being an undocumented immigrant in the United States has been pivotal
          in shaping who I am — and everything I make.
        </p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .about-page {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .page-header {
    margin-bottom: var(--space-2xl);
  }

  .page-title {
    font-size: 2rem;
    margin-bottom: var(--space-xs);
  }

  .page-subtitle {
    font-size: 1.2rem;
    color: var(--color-pencil);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .about-photo-wrapper {
    width: fit-content;
  }

  .about-photo {
    width: 220px;
    height: auto;
    display: block;
  }

  .about-text h2 {
    font-size: 1.4rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .about-text h2:first-child {
    margin-top: 0;
  }

  .about-text ul {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .about-text li {
    margin-bottom: var(--space-xs);
  }

</style>
