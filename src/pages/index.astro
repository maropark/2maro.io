---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import TornEdge from '../components/TornEdge.astro';
import DateStamp from '../components/DateStamp.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allMusings = await getCollection('musings', ({ data }) => data.published);
const musings = allMusings.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Home">

  <!-- ═══════════ AUTHOR'S NOTE SPREAD ═══════════ -->
  <section class="spread spread--authors" id="authors-note">
    <div class="spread-header">
      <h2 class="spread-title">Author's Note</h2>
      <p class="spread-subtitle handwritten">the person behind the notebook</p>
    </div>

    <div class="about-content">
      <div class="about-portrait taped-image">
        <img src="/blog-profile.jpeg" alt="Maro" class="about-photo" />
      </div>

      <div class="about-text notebook-lines">
        <h3>Hey, I'm Maro.</h3>
        <p>
          Ex-immigrant rights organizer, coder, and creator.
        </p>
        <p>
          I build for community, resistance, and expression.
          Being an undocumented immigrant in the United States has been pivotal
          in shaping who I am — and everything I make.
        </p>
      </div>
    </div>
  </section>

  <TornEdge />

  <!-- ═══════════ JOURNAL SPREAD ═══════════ -->
  <section class="spread spread--journal spread--lined" id="journal">
    <div class="spread-header">
      <h2 class="spread-title">Journal</h2>
      <p class="spread-subtitle handwritten">things I wrote down before I forget</p>
    </div>

    <div class="entry-stack">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="entry-block paper-card">
          <div class="entry-block-meta">
            <DateStamp date={post.data.date} />
            {post.data.featured && <span class="entry-featured handwritten">featured</span>}
          </div>
          <h3 class="entry-block-title">{post.data.title}</h3>
          <p class="entry-block-excerpt">{post.data.description}</p>
          {post.data.tags?.length > 0 && (
            <div class="entry-block-tags">
              {post.data.tags.slice(0, 3).map((tag: string) => (
                <span class="entry-tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

    <div class="spread-more">
      <a href="/blog" class="tape-link tape-link--red">all entries →</a>
    </div>
  </section>

  <TornEdge />

  <!-- ═══════════ WORKSHOP SPREAD ═══════════ -->
  <section class="spread spread--workshop" id="workshop">
    <div class="spread-header">
      <h2 class="spread-title">Workshop</h2>
      <p class="spread-subtitle handwritten">things I'll ship&hellip; 2maro</p>
    </div>

    <div class="entry-stack">
      {projects.map((project) => (
        <div class="entry-block paper-card paper-stacked" style="position: relative;">
          {project.data.icon && (
            <div class="entry-icon-tape" aria-hidden="true">
              <img src={project.data.icon} alt="" width="36" height="36" />
            </div>
          )}
          <div class="entry-block-meta">
            <span class={`entry-status entry-status--${project.data.status} handwritten`}>{project.data.status}</span>
            {project.data.tech?.length > 0 && (
              <div class="entry-block-tags">
                {project.data.tech.slice(0, 4).map((t: string) => (
                  <span class="entry-tag">{t}</span>
                ))}
              </div>
            )}
          </div>
          <h3 class="entry-block-title">{project.data.title}</h3>
          <p class="entry-block-excerpt">{project.data.description}</p>
          <div class="entry-block-links">
            {project.data.github && (
              <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="github-tape" aria-label="GitHub">
                <img src="/icons/github.svg" alt="" width="16" height="16" class="github-tape-icon" />
                <span>GitHub</span>
              </a>
            )}
            {project.data.url && (
              <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="tape-link tape-link--teal">Live</a>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="spread-more">
      <a href="/projects" class="tape-link tape-link--teal">all projects →</a>
    </div>
  </section>


  <TornEdge />

  <!-- ═══════════ THOUGHTS FOR TOMORROW SPREAD ═══════════ -->
  <section class="spread spread--thoughts" id="thoughts">
    <div class="spread-header">
      <h2 class="spread-title">Thoughts for Tomorrow</h2>
      <p class="spread-subtitle handwritten">musings. not quite ideas. not quite plans.</p>
    </div>

    <ul class="thoughts-list notebook-lines">
      {musings.slice(0, 3).map((entry) => (
        <li class="thought-item">
          <span class="thought-bullet handwritten">—</span>
          <span>{entry.data.title}</span>
        </li>
      ))}
    </ul>

    <div class="spread-more">
      <a href="/musings" class="tape-link tape-link--blue">all musings →</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Spreads */
  .spread {
    padding: var(--space-2xl) 0 var(--space-3xl);
    scroll-margin-top: 100px;
  }

  /* Notebook ruled lines — journal section background */
  .spread--lined {
    background-image: repeating-linear-gradient(
      transparent,
      transparent 31px,
      rgba(0, 0, 0, 0.06) 31px,
      rgba(0, 0, 0, 0.06) 32px
    );
    background-position: 0 8px;
  }

  .spread-header {
    position: relative;
    margin-bottom: var(--space-xl);
    padding-left: var(--space-sm);
  }

  .spread-title {
    font-size: 1.8rem;
    margin-bottom: var(--space-xs);
    display: inline-block;
    position: relative;
    z-index: 0;
  }

  /* Torn-paper tape highlight — covers only the title letters */
  .spread-title::before {
    content: '';
    position: absolute;
    inset: 1px -6px;
    z-index: -1;
    transform: rotate(-0.8deg);
    clip-path: polygon(
      0% 15%,  2% 4%,  5% 18%,  8% 6%,  12% 20%, 16% 4%,
      20% 17%, 24% 6%,  28% 19%, 32% 3%,  36% 17%, 40% 7%,
      44% 20%, 48% 5%,  52% 18%, 56% 4%,  60% 17%, 64% 7%,
      68% 20%, 72% 4%,  76% 18%, 80% 7%,  84% 20%, 88% 4%,
      92% 17%, 96% 7%,  100% 17%,
      100% 83%, 98% 96%, 94% 79%, 90% 93%, 86% 79%, 82% 96%,
      78% 81%, 74% 95%, 70% 79%, 66% 93%, 62% 81%, 58% 96%,
      54% 79%, 50% 93%, 46% 81%, 42% 96%, 38% 79%, 34% 93%,
      30% 81%, 26% 95%, 22% 79%, 18% 93%, 14% 81%, 10% 95%,
      6% 79%,  3% 93%,  0% 83%
    );
  }

  .spread--journal .spread-title::before {
    background: var(--color-stamp-red);
    opacity: 0.35;
  }

  .spread--workshop .spread-title::before {
    background: var(--color-washi-teal);
    opacity: 0.4;
  }

  .spread--authors .spread-title::before {
    background: var(--color-sticky-yellow);
    opacity: 0.55;
  }

  .spread--thoughts .spread-title::before {
    background: var(--color-ballpoint-blue);
    opacity: 0.25;
  }

  .spread-subtitle {
    font-size: 1.2rem;
    color: var(--color-pencil);
  }

  .spread-more {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px dashed var(--color-kraft);
    text-align: right;
  }

  /* Entry blocks — paper card stack */
  .entry-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .entry-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    text-decoration: none;
    color: inherit;
  }

  a.entry-block:hover .entry-block-title {
    color: var(--color-stamp-red);
  }

  .entry-block-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .entry-block-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .entry-block-excerpt {
    font-size: 0.95rem;
    color: var(--color-pencil);
    line-height: 1.65;
    margin: 0;
  }

  .entry-block-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: var(--space-xs);
  }

  .entry-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    padding: 1px 6px;
    background: var(--color-paper-alt);
    border: 1px solid var(--color-kraft);
    border-radius: 2px;
    color: var(--color-pencil);
    white-space: nowrap;
  }

  .entry-featured {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-stamp-red);
    opacity: 0.8;
  }

  .entry-status {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .entry-status--active   { color: var(--color-washi-teal); }
  .entry-status--shipped  { color: var(--color-stamp-red); }
  .entry-status--idea     { color: var(--color-sticky-yellow); }
  .entry-status--archived { color: var(--color-pencil); }

  .entry-block-links {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
    padding-top: var(--space-sm);
    border-top: 1px dashed var(--color-kraft);
    flex-wrap: wrap;
  }

  .entry-icon-tape {
    position: absolute;
    top: -13px;
    right: 14px;
    width: 36px;
    height: 36px;
    transform: rotate(6deg);
    filter: drop-shadow(1px 2px 3px rgba(0,0,0,0.18));
    pointer-events: none;
  }

  .entry-icon-tape img {
    width: 100%;
    height: 100%;
  }

  .tape-link {
    display: inline-block;
    font-family: 'Caveat', cursive;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    padding: 3px 10px;
    opacity: 0.8;
    transform: rotate(-1deg);
    transition: opacity 0.15s, transform 0.15s;
    white-space: nowrap;
  }

  .tape-link:nth-child(even) {
    transform: rotate(1deg);
  }

  .tape-link:hover {
    opacity: 1;
    transform: rotate(0deg) scale(1.06);
  }

  .tape-link--teal   { background: var(--color-washi-teal, #4A9B8E);       color: white; }
  .tape-link--yellow { background: var(--color-sticky-yellow, #F2C94C);   color: var(--color-ink, #2C2520); }
  .tape-link--red    { background: var(--color-stamp-red, #C1440E);        color: white; }
  .tape-link--blue   { background: var(--color-ballpoint-blue, #2D5FAA);  color: white; }

  /* GitHub washi tape — rectangular strip, blue, stuck to card */
  .github-tape {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: 'Caveat', cursive;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    color: white;
    padding: 3px 10px;
    background: var(--color-ballpoint-blue, #2D5FAA);
    opacity: 0.85;
    transform: rotate(-2deg);
    transform-origin: left center;
    transition: opacity 0.15s, transform 0.15s;
    filter: drop-shadow(1px 2px 3px rgba(0,0,0,0.18));
    white-space: nowrap;
  }

  .github-tape:nth-child(even) {
    transform: rotate(1.5deg);
    transform-origin: right center;
  }

  .github-tape:hover {
    opacity: 1;
    transform: rotate(0deg) scale(1.04);
  }

  .github-tape-icon {
    filter: invert(1);
    opacity: 0.9;
  }

  /* Author's Note */
  .about-portrait {
    margin-bottom: var(--space-lg);
  }

  .about-photo {
    width: 180px;
    height: auto;
    display: block;
  }

  .about-text h3 {
    font-size: 1.4rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .about-text h3:first-child {
    margin-top: 0;
  }

  /* Thoughts for Tomorrow */
  .thoughts-list {
    list-style: none;
    padding: var(--space-lg) var(--space-md);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .thought-item {
    display: flex;
    gap: var(--space-md);
    align-items: baseline;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .thought-bullet {
    font-size: 1.4rem;
    color: var(--color-ballpoint-blue);
    flex-shrink: 0;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .spread-title    { font-size: 1.5rem; }

    .entry-block-title { font-size: 1.1rem; }

    .photo-placeholder {
      width: 150px;
      height: 150px;
    }
  }
</style>
