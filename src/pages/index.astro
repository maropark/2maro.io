---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import TornEdge from '../components/TornEdge.astro';
import WashiTape from '../components/WashiTape.astro';
import DateStamp from '../components/DateStamp.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Home">

  <!-- Hero: Notebook Cover -->
  <section class="hero">
    <div class="hero-notebook">
      <div class="hero-tape" aria-hidden="true"></div>
      <h1 class="hero-title">
        <span class="hero-title-main">The Backlog</span>
        <span class="hero-title-sub handwritten">notes from an open-source builder</span>
      </h1>
      <p class="hero-intro">
        A retro dev journal by <strong>Maro Park</strong>. Projects, learnings, and things
        I'll ship&hellip; 2maro.
      </p>
      <a href="#workshop" class="jump-link handwritten">↓ project backlog</a>
    </div>
  </section>

  <!-- ═══════════ AUTHOR'S NOTE SPREAD ═══════════ -->
  <section class="spread" id="authors-note">
    <div class="spread-header">
      <WashiTape color="yellow" rotation={-1} class="spread-tape" />
      <h2 class="spread-title">Author's Note</h2>
      <p class="spread-subtitle handwritten">the person behind the notebook</p>
    </div>

    <div class="about-content">
      <div class="about-photo-wrapper">
        <div class="photo-placeholder">
          <span class="handwritten">photo goes here</span>
        </div>
      </div>

      <div class="about-text notebook-lines">
        <h3>Hey, I'm Maro.</h3>
        <p>
          I'm a developer who values open source and builds things that matter.
          This site is my backlog — a public journal of projects, learnings,
          and ideas that I'll ship&hellip; eventually.
        </p>
        <p>
          I believe in building in the open, sharing what I learn, and creating
          tools that help people. Most of my work lives on GitHub where anyone
          can use, fork, or improve it.
        </p>

        <div class="about-links">
          <a href="https://github.com/maropark" class="about-link handwritten">GitHub &rarr;</a>
          <a href="/about" class="about-link handwritten">full note &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <TornEdge />

  <!-- ═══════════ JOURNAL SPREAD ═══════════ -->
  <section class="spread" id="journal">
    <div class="spread-header">
      <WashiTape color="red" rotation={-2} class="spread-tape" />
      <h2 class="spread-title">Journal</h2>
      <p class="spread-subtitle handwritten">things I wrote down before I forget</p>
    </div>

    <div class="entry-stack">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="entry-block paper-card">
          <div class="entry-block-meta">
            <DateStamp date={post.data.date} />
            {post.data.featured && <span class="entry-featured handwritten">featured</span>}
          </div>
          <h3 class="entry-block-title">{post.data.title}</h3>
          <p class="entry-block-excerpt">{post.data.description}</p>
          {post.data.tags?.length > 0 && (
            <div class="entry-block-tags">
              {post.data.tags.slice(0, 3).map((tag: string) => (
                <span class="entry-tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

    <div class="spread-more">
      <a href="/blog" class="more-link handwritten">all entries &rarr;</a>
    </div>
  </section>

  <TornEdge />

  <!-- ═══════════ WORKSHOP SPREAD ═══════════ -->
  <section class="spread" id="workshop">
    <div class="spread-header">
      <WashiTape color="teal" rotation={1} class="spread-tape" />
      <h2 class="spread-title">Workshop</h2>
      <p class="spread-subtitle handwritten">things pinned to the board</p>
    </div>

    <div class="entry-stack">
      {projects.map((project) => (
        <div class="entry-block paper-card paper-stacked">
          <div class="entry-block-meta">
            <span class={`entry-status entry-status--${project.data.status} handwritten`}>{project.data.status}</span>
            {project.data.tech?.length > 0 && (
              <div class="entry-block-tags">
                {project.data.tech.slice(0, 4).map((t: string) => (
                  <span class="entry-tag">{t}</span>
                ))}
              </div>
            )}
          </div>
          <h3 class="entry-block-title">{project.data.title}</h3>
          <p class="entry-block-excerpt">{project.data.description}</p>
          <div class="entry-block-links">
            {project.data.github && (
              <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="entry-ext-link">GitHub &rarr;</a>
            )}
            {project.data.url && (
              <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="entry-ext-link">Live &rarr;</a>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="spread-more">
      <a href="/projects" class="more-link handwritten">all projects &rarr;</a>
    </div>
  </section>


  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .hero-notebook {
    background: var(--color-paper);
    border: 1px solid var(--color-kraft);
    box-shadow: var(--shadow-stacked);
    padding: var(--space-2xl) var(--space-xl);
    position: relative;
  }

  .hero-tape {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    width: 140px;
    height: 28px;
    background: var(--color-sticky-yellow);
    opacity: 0.5;
  }

  .hero-title {
    margin-bottom: var(--space-lg);
  }

  .hero-title-main {
    display: block;
    font-size: 2.6rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .hero-title-sub {
    display: block;
    font-size: 1.4rem;
    color: var(--color-pencil);
    margin-top: var(--space-xs);
  }

  .hero-intro {
    font-size: 1.05rem;
    color: var(--color-pencil);
    line-height: 1.7;
    max-width: 540px;
  }

  .jump-link {
    display: inline-block;
    margin-top: var(--space-lg);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-ballpoint-blue);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity var(--transition-fast), color var(--transition-fast);
  }

  .jump-link:hover {
    opacity: 1;
    color: var(--color-stamp-red);
  }

  /* Spreads */
  .spread {
    padding: var(--space-2xl) 0 var(--space-3xl);
    scroll-margin-top: 100px;
  }

  .spread-header {
    position: relative;
    margin-bottom: var(--space-xl);
    padding-left: var(--space-sm);
  }

  .spread-title {
    font-size: 1.8rem;
    margin-bottom: var(--space-xs);
  }

  .spread-subtitle {
    font-size: 1.2rem;
    color: var(--color-pencil);
  }

  .spread-header :global(.spread-tape) {
    position: absolute;
    top: -8px;
    left: -12px;
  }

  .spread-more {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px dashed var(--color-kraft);
    text-align: right;
  }

  .more-link {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-ballpoint-blue);
    text-decoration: none;
  }

  .more-link:hover {
    color: var(--color-stamp-red);
  }

  /* Entry blocks — paper card stack */
  .entry-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .entry-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    text-decoration: none;
    color: inherit;
  }

  a.entry-block:hover .entry-block-title {
    color: var(--color-stamp-red);
  }

  .entry-block-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .entry-block-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .entry-block-excerpt {
    font-size: 0.95rem;
    color: var(--color-pencil);
    line-height: 1.65;
    margin: 0;
  }

  .entry-block-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: var(--space-xs);
  }

  .entry-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    padding: 1px 6px;
    background: var(--color-paper-alt);
    border: 1px solid var(--color-kraft);
    border-radius: 2px;
    color: var(--color-pencil);
    white-space: nowrap;
  }

  .entry-featured {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-stamp-red);
    opacity: 0.8;
  }

  .entry-status {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .entry-status--active   { color: var(--color-washi-teal); }
  .entry-status--shipped  { color: var(--color-stamp-red); }
  .entry-status--idea     { color: var(--color-sticky-yellow); }
  .entry-status--archived { color: var(--color-pencil); }

  .entry-block-links {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-xs);
    padding-top: var(--space-sm);
    border-top: 1px dashed var(--color-kraft);
  }

  .entry-ext-link {
    font-family: 'Caveat', cursive;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ballpoint-blue);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .entry-ext-link:hover {
    color: var(--color-stamp-red);
  }

  /* Author's Note */
  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .about-photo-wrapper {
    width: fit-content;
  }

  .photo-placeholder {
    width: 200px;
    height: 200px;
    background: var(--color-paper-alt);
    border: 1px solid var(--color-kraft);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-pencil);
    font-size: 1.1rem;
  }

  .about-text h3 {
    font-size: 1.4rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .about-text h3:first-child {
    margin-top: 0;
  }

  .about-links {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px dashed var(--color-kraft);
    display: flex;
    gap: var(--space-lg);
  }

  .about-link {
    font-family: 'Caveat', cursive;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-ballpoint-blue);
    text-decoration: none;
  }

  .about-link:hover {
    color: var(--color-stamp-red);
  }

  @media (max-width: 640px) {
    .hero-title-main { font-size: 2rem; }
    .hero-title-sub  { font-size: 1.1rem; }
    .hero-notebook   { padding: var(--space-xl) var(--space-lg); }
    .spread-title    { font-size: 1.5rem; }

    .entry-block-title { font-size: 1.1rem; }

    .photo-placeholder {
      width: 150px;
      height: 150px;
    }
  }
</style>
